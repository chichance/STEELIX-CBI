    if [[ -f "/Library/LaunchDaemons/$D.plist" ]]; then
        launchctl unload "/Library/LaunchDaemons/$D.plist" 2>/dev/null
        rm "/Library/LaunchDaemons/$D.plist"
    fi
done

echo "[*] Waiting for ports to clear..."
for PORT in "${PORTS[@]}"; do
    RETRIES=10
    while lsof -i :$PORT >/dev/null 2>&1 && [[ $RETRIES -gt 0 ]]; do
        lsof -ti :$PORT | xargs kill -9 >/dev/null 2>&1
        sleep 1
        ((RETRIES--))
    done
done

