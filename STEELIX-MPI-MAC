import pymysql, pandas as pd, re, joblib, sys, json, os

def get_db_config():
    cfg = {}
    with open("/etc/steelix.env") as f:
        for line in f: k, _, v = line.strip().partition("="); cfg[k] = v
    return {
        'host': cfg.get('STEELIX_DB_HOST', '127.0.0.1'),
        'user': cfg.get('STEELIX_DB_USER'),
        'password': cfg.get('STEELIX_DB_PASS'),
        'database': cfg.get('STEELIX_DB_NAME')
    }

def train():
    from sklearn.ensemble import IsolationForest
    db = get_db_config()
    try:
        conn = pymysql.connect(**db)
        df = pd.read_sql("SELECT raw_payload FROM system_logs WHERE event_type LIKE 'HEARTBEAT%' ORDER BY id DESC LIMIT 2000", conn)
        conn.close()
    except Exception as e: sys.exit(1)

    data = []
    for payload_str in df['raw_payload']:
        try:
            p = json.loads(payload_str); load = float(p.get('load', 0))
            match = re.search(r'\[(\d+)', p.get('signature', ''))
            if match: data.append([load, int(match.group(1))])
        except: continue

    if len(data) < 10: print("[!] Not enough data to train."); sys.exit(1)
    
    model = IsolationForest(contamination=0.1, random_state=42)
    model.fit(pd.DataFrame(data, columns=[0, 1]))
    joblib.dump(model, "/opt/Steelix_Fusion/cortex/kanto_model.pkl")
    print("[*] AI Model trained.")

if __name__ == "__main__": train()
