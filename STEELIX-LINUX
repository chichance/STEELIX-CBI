import pymysql, pandas as pd, re, joblib, sys, json, os

def get_db_config():
    cfg = {}
    try:
        with open("/etc/steelix.env") as f:
            for line in f:
                k, _, v = line.strip().partition("=")
                cfg[k] = v
    except Exception as e:
        print(f"[!] Could not read /etc/steelix.env: {e}")
        sys.exit(1)
    return {
        'host':     cfg.get('STEELIX_DB_HOST', 'localhost'),
        'user':     cfg.get('STEELIX_DB_USER'),
        'password': cfg.get('STEELIX_DB_PASS'),
        'database': cfg.get('STEELIX_DB_NAME'),
    }

def train():
    from sklearn.ensemble import IsolationForest
    db = get_db_config()
    try:
        conn = pymysql.connect(**db)
        df = pd.read_sql(
            "SELECT raw_payload FROM system_logs "
            "WHERE event_type LIKE 'HEARTBEAT%' "
            "ORDER BY id DESC LIMIT 2000",
            conn
        )
        conn.close()
    except Exception as e:
        print(f"[!] DB error: {e}")
        sys.exit(1)

    if len(df) < 10:
        print("[!] Not enough data to train (need >= 10 heartbeat rows).")
        sys.exit(1)

    data = []
    for payload_str in df['raw_payload']:
        try:
            p = json.loads(payload_str)
            load = float(p.get('load', 0))
            sig = p.get('signature', '')
            match = re.search(r'\[(\d+)', sig)
            if not match:
                continue
            val = int(match.group(1))
            data.append([load, val])
        except Exception:
            continue

    if len(data) < 10:
        print("[!] Not enough parseable rows after extraction.")
        sys.exit(1)

    df_train = pd.DataFrame(data, columns=[0, 1])
    model = IsolationForest(contamination=0.1, random_state=42)
    model.fit(df_train)
    out = "/opt/Steelix_Fusion/cortex/kanto_model.pkl"
    joblib.dump(model, out)
    print(f"[*] AI Model trained on {len(data)} samples → {out}")

if __name__ == "__main__":
    train()
PY_TRAIN

