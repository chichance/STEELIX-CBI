import pymysql, datetime, sys

sys.path.append("/opt/Steelix_Fusion/pokegear")
import phone

def get_db_config():
    cfg = {}
    try:
        with open("/etc/steelix.env") as f:
            for line in f:
                k, _, v = line.strip().partition("=")
                cfg[k] = v
    except Exception as e:
        sys.exit(1)
    return {
        'host':     cfg.get('STEELIX_DB_HOST', 'localhost'),
        'user':     cfg.get('STEELIX_DB_USER'),
        'password': cfg.get('STEELIX_DB_PASS'),
        'database': cfg.get('STEELIX_DB_NAME'),
    }

def generate_summary():
    db = get_db_config()
    try:
        conn = pymysql.connect(**db)
        with conn.cursor() as c:
            # Aggregate events over the last 24 hours
            c.execute("""
                SELECT event_type, COUNT(*) FROM system_logs 
                WHERE timestamp >= NOW() - INTERVAL 1 DAY 
                GROUP BY event_type
            """)
            stats = c.fetchall()

            # Retrieve distinct anomalies
            c.execute("""
                SELECT node_id, metric_signature FROM system_logs 
                WHERE event_type = 'HEARTBEAT_ANOMALY' 
                AND timestamp >= NOW() - INTERVAL 1 DAY
            """)
            anomalies = c.fetchall()

            # Identify critical honeypot hits
            c.execute("""
                SELECT raw_payload FROM system_logs 
                WHERE event_type = 'EVENT' 
                AND raw_payload LIKE '%CRITICAL%'
                AND timestamp >= NOW() - INTERVAL 1 DAY
            """)
            criticals = c.fetchall()
            
    except Exception as e:
        print(f"Database connection failed: {e}")
        return
    finally:
        conn.close()

    total_events = sum([row[1] for row in stats]) if stats else 0
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    
    report = f"==================================================\n"
    report += f"   SILPH CO. SYSTEM BRIEFING ({now})\n"
    report += f"==================================================\n"
    report += f"Total Activity Logged (24h): {total_events}\n\n"
    
    report += "EVENT BREAKDOWN:\n"
    if stats:
        for row in stats:
            report += f"  - {row[0]:<20}: {row[1]}\n"
    else:
        report += "  - No events recorded.\n"
        
    report += f"\nANOMALIES DETECTED: {len(anomalies)}\n"
    for a in anomalies:
        report += f"  > [{a[0]}] {a[1]}\n"

    report += f"\nCRITICAL INCIDENTS (RED GYARADOS): {len(criticals)}\n"
    for c in criticals:
        report += f"  ! {c[0]}\n"
        
    report += "==================================================\n"

    # Save to disk overwriting previous daily summary
    with open("/var/log/steelix/daily_summary.txt", "w") as f:
        f.write(report)

    # Ping the pokegear logging subsystem
    phone.make_call("REPORTER", f"Daily Summary Generated. Events: {total_events}. Anomalies: {len(anomalies)}", "INFO")
    print("Daily report successfully generated.")

