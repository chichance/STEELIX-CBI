#!/usr/bin/env python3
import sys, socket, json, os

G, Y, R, X, C = "\033[96m", "\033[93m", "\033[91m", "\033[0m", "\033[94m"
BRAIN_ADMIN_PORT = 3003
INGEST_PORT      = 3001
ALLOWED_CMDS     = {"STANDBY", "SILENCE", "ALERT", "RESET"}

def send_raw(port, payload_bytes, recv=False):
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(5)
        s.connect(('127.0.0.1', port))
        s.sendall(payload_bytes)
        data = s.recv(4096) if recv else b""
        s.close()
        return data
    except Exception as e:
        print(f"{R}[!] Connection error: {e}{X}")
        return None

def status():
    data = send_raw(BRAIN_ADMIN_PORT, b"STATUS", recv=True)
    if not data:
        print(f"{R}[!] DISCONNECTED (is steelix-brain running?){X}")
        return

    try:
        d = json.loads(data.decode())
    except json.JSONDecodeError:
        print(f"{R}[!] Bad response from brain.{X}")
        return

    th = d.get("threat_level", "UNKNOWN")
    bc = d.get("broadcast", "STANDBY")
    c  = R if th == "RED" else (Y if th == "YELLOW" else G)

    print(f"\n\033[1mSTEELIX FUSION (GEN II){X}")
    print("=" * 60)
    print(f" GLOBAL STATE:  {c}{th}{X}")
    print(f" RADIO TOWER:   {R if bc != 'STANDBY' else G}{bc}{X}")
    print("=" * 60)

    log_path = "/opt/Steelix_Fusion/pokegear/call_history.log"
    try:
        with open(log_path) as f:
            for line in f.readlines()[-2:]:
                print(f" \033[90m> {line.strip()}{X}")
    except FileNotFoundError:
        pass

    print("=" * 60)
    nodes = d.get("nodes_detail", {})
    if not nodes:
        print(f" {R}NO ACTIVE REGIONS{X}")
    else:
        print(f"{'BADGE':<15} {'STATUS':<12} SIGNATURE")
        print("-" * 60)
        badges = ["BOULDER","CASCADE","THUNDER","RAINBOW","SOUL","MARSH","VOLCANO","EARTH"]
        for b in badges:
            key = f"REGION_{b}"
            if key in nodes:
                tel = nodes[key].get('telemetry', {})
                sig = tel.get('signature', '-')
                sta = tel.get('status', '?')
                col = R if sta == "ANOMALY" else G
                print(f"{G}{b:<15}{X} {col}{sta:<12}{X} {sig}")
    print()

def broadcast(cmd):
    cmd = cmd.upper().strip()
    if cmd not in ALLOWED_CMDS:
        print(f"{R}[!] Unknown command '{cmd}'. Allowed: {ALLOWED_CMDS}{X}")
        return
    payload = json.dumps({"event": f"BROADCAST:{cmd}"}).encode()
    send_raw(INGEST_PORT, payload)
    print(f"{G}[*] Order '{cmd}' sent.{X}")

def show_report():
    try:
        with open("/var/log/steelix/daily_summary.txt", "r") as f:
            print(f.read())
    except FileNotFoundError:
        print(f"{R}[!] No daily report found. The reporter runs at midnight.{X}")
        print(f"{Y}[*] You can trigger it manually with: systemctl start steelix-reporter.service{X}")

def usage():
    print(f"""
{G}steelix{X} — Steelix Fusion CLI

  {C}steelix{X}                  Show system status
  {C}steelix broadcast <CMD>{X}  Send order to all agents
                           Commands: {', '.join(sorted(ALLOWED_CMDS))}
  {C}steelix train{X}            Train the AI anomaly model
  {C}steelix logs <region>{X}    Tail the log for a region
  {C}steelix report{X}          View the latest 24h system summary
""")

if __name__ == "__main__":
    if len(sys.argv) == 1:
        status()
    elif sys.argv[1] == "broadcast" and len(sys.argv) > 2:
        broadcast(sys.argv[2])
    elif sys.argv[1] == "train":
        os.execv("/usr/local/bin/steelix-train", ["/usr/local/bin/steelix-train"])
    elif sys.argv[1] == "logs" and len(sys.argv) > 2:
        region = sys.argv[2].lower()
        log = f"/var/log/steelix/{region}.log"
        os.execv("/usr/bin/tail", ["/usr/bin/tail", "-f", log])
    elif sys.argv[1] == "report":
        show_report()
    else:
        usage()
CLI_TOOL
