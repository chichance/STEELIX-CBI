import socket, json, time, threading, os, signal, sys, pymysql, joblib, re, pandas as pd
from concurrent.futures import ThreadPoolExecutor
sys.path.append("/opt/Steelix_Fusion/pokegear")
import phone

PID_FILE = "/var/run/steelix/brain.pid"
READY_FILE = "/var/run/steelix/brain.ready"

def get_db_config():
    cfg = {}
    with open("/etc/steelix.env") as f:
        for line in f: k, _, v = line.strip().partition("="); cfg[k] = v
    return {
        'host': cfg.get('STEELIX_DB_HOST', '127.0.0.1'),
        'user': cfg.get('STEELIX_DB_USER'),
        'password': cfg.get('STEELIX_DB_PASS'),
        'database': cfg.get('STEELIX_DB_NAME'), 'autocommit': True
    }

class FusionBrain:
    def __init__(self):
        self.lock = threading.Lock(); self.nodes = {}
        self.threat_level = "GREEN"; self.broadcast_cmd = "STANDBY"
        self.ports = {'ingest': 3001, 'admin': 3003, 'pulse': 3004}
        self.db = get_db_config(); self.model = None
        try: self.model = joblib.load("/opt/Steelix_Fusion/cortex/kanto_model.pkl")
        except: pass

    def log(self, nid, evt, sig, payload, score=None):
        try:
            conn = pymysql.connect(**self.db)
            with conn.cursor() as c: c.execute("INSERT INTO system_logs (node_id, event_type, metric_signature, raw_payload, ai_score) VALUES (%s, %s, %s, %s, %s)", (nid, evt, sig, json.dumps(payload), score))
            conn.close()
        except: pass

    def judge(self, payload):
        if not self.model: return None
        try:
            load = float(payload.get('load', 0))
            match = re.search(r'\[(\d+)', payload.get('signature', ''))
            if not match: return None
            return int(self.model.predict(pd.DataFrame([[load, int(match.group(1))]], columns=[0, 1]))[0])
        except: return None

    def handle(self, conn, p_type):
        with conn:
            try:
                conn.settimeout(5); data = conn.recv(4096)
                if not data: return
                if p_type == 'admin':
                    with self.lock:
                        now = time.time()
                        self.nodes = {k: v for k, v in self.nodes.items() if now - v['last_seen'] < 20}
                        conn.sendall(json.dumps({"system": "STEELIX macOS", "threat_level": self.threat_level, "broadcast": self.broadcast_cmd, "nodes_detail": self.nodes}).encode())
                elif p_type == 'pulse':
                    pl = json.loads(data.decode()); nid = str(pl.get('id', 'UNKNOWN'))[:50]; tel = pl.get('data', {})
                    verdict = self.judge(tel); tag = "NORMAL"
                    if verdict == -1:
                        tag = "ANOMALY"; self.threat_level = "YELLOW"
                        phone.make_call(nid, f"Anomaly: {tel.get('signature')}", "HIGH")
                    tel['status'] = tag
                    with self.lock: self.nodes[nid] = {'last_seen': time.time(), 'telemetry': tel}
                    conn.sendall(json.dumps({"order": self.broadcast_cmd}).encode())
                    self.log(nid, f"HEARTBEAT_{tag}", tel.get('signature', ''), tel, verdict)
                elif p_type == 'ingest':
                    pl = json.loads(data.decode()); msg = str(pl.get('event', ''))[:500].upper()
                    if "BROADCAST:" in msg:
                        cmd = msg.split(":", 1)[1].strip()
                        if cmd in {"STANDBY", "SILENCE", "ALERT", "RESET"}:
                            with self.lock: self.broadcast_cmd = cmd
                            phone.make_call("RADIO_TOWER", f"Order: {cmd}", "CMD")
                    elif "CRITICAL" in msg:
                        with self.lock: self.threat_level = "RED"
                        phone.make_call("RED_GYARADOS", msg, "URGENT")
                    elif "RESET" in msg:
                        with self.lock: self.threat_level = "GREEN"; self.broadcast_cmd = "STANDBY"
                    self.log("CORE", "EVENT", msg, pl)
            except: pass

    def listener(self, port, p_type):
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        s.bind(('0.0.0.0', port)); s.listen(50)
        with ThreadPoolExecutor(max_workers=20) as exe:
            while True:
                try: conn, _ = s.accept(); exe.submit(self.handle, conn, p_type)
                except: pass

    def start(self):
        with open(PID_FILE, "w") as f: f.write(str(os.getpid()))
        for p_type, port in self.ports.items():
            threading.Thread(target=self.listener, args=(port, p_type), daemon=True).start()
        time.sleep(0.5)
        with open(READY_FILE, "w") as f: f.write(str(time.time()))
        while True: time.sleep(1)

if __name__ == "__main__": FusionBrain().start()
