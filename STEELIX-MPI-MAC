wait_for_port() {
    local PORT=$1
    local LABEL=$2
    local RETRIES=20
    echo -n "[*] Waiting for $LABEL on :$PORT"
    for i in $(seq 1 $RETRIES); do
        if lsof -i :$PORT -sTCP:LISTEN >/dev/null 2>&1; then
            echo " OK"
            return 0
        fi
        echo -n "."
        sleep 1
    done
    echo " TIMEOUT"
    return 1
}

