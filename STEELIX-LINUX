PORTS=(3001 3003 3004 8888)
SERVICES=(steelix-brain steelix-gyarados steelix-reporter.timer $(for g in boulder cascade thunder rainbow soul marsh volcano earth; do echo steelix-region-$g; done))

echo "=================================================="
echo "   STARTING STEELIX GRAND UNIFICATION DEPLOYMENT  "
echo "=================================================="

# ============================================================
# UTILITY: wait for a TCP port to open (used for readiness)
# ============================================================
wait_for_port() {
    local PORT=$1
    local LABEL=$2
    local RETRIES=20
    echo -n "[*] Waiting for $LABEL on :$PORT"
    for i in $(seq 1 $RETRIES); do
        if ss -tlnH "sport = :$PORT" | grep -q "$PORT"; then
            echo " OK"
            return 0
        fi
        echo -n "."
        sleep 1
    done
    echo " TIMEOUT"
    return 1
}

# ============================================================
# UTILITY: wait for MariaDB to accept connections
# ============================================================
wait_for_mysql() {
    local RETRIES=20
    echo -n "[*] Waiting for MariaDB"
    for i in $(seq 1 $RETRIES); do
        if mysqladmin ping --silent 2>/dev/null; then
            echo " OK"
            return 0
        fi
        echo -n "."
        sleep 1
    done
    echo " TIMEOUT"
    return 1
}

# ============================================================
# PHASE 1: CLEAN SHUTDOWN — targeted, ordered, verified
# ============================================================
echo -e "\n>>> PHASE 1: CLEAN SHUTDOWN"

echo "[*] Stopping systemd services in dependency order..."
for GYM in boulder cascade thunder rainbow soul marsh volcano earth; do
    systemctl stop steelix-region-$GYM 2>/dev/null
done
systemctl stop steelix-reporter.timer 2>/dev/null
systemctl stop steelix-brain 2>/dev/null
systemctl stop steelix-gyarados 2>/dev/null

echo "[*] Disabling services..."
for SVC in "${SERVICES[@]}"; do
    systemctl disable "$SVC" 2>/dev/null
done

echo "[*] Waiting for ports to clear..."
for PORT in "${PORTS[@]}"; do
    RETRIES=10
    while ss -tlnH "sport = :$PORT" | grep -q "$PORT" && [[ $RETRIES -gt 0 ]]; do
        fuser -k "$PORT/tcp" >/dev/null 2>&1
        sleep 1
        ((RETRIES--))
    done
    if ss -tlnH "sport = :$PORT" | grep -q "$PORT"; then
        echo "[!] WARNING: Port $PORT still in use. Check manually."
    else
        echo "[*] Port $PORT cleared."
    fi
done

echo "[*] Removing PID files..."
mkdir -p "$PID_DIR"
rm -f "$PID_DIR"/*.pid

echo "[*] Purging legacy install directory..."
rm -rf "$INSTALL_DIR"
mkdir -p "$INSTALL_DIR"/{brain,agent,cortex,pokegear,gyarados,reporter}
mkdir -p "$LOG_DIR"

# ============================================================
