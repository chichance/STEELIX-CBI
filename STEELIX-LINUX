import datetime, os, threading

LOG_FILE = "/opt/Steelix_Fusion/pokegear/call_history.log"
_lock = threading.Lock()

def make_call(source, message, priority="NORMAL"):
    ts = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    source = str(source)[:50]
    message = str(message)[:200]
    priority = str(priority)[:20]
    line = f"[{ts}] [{source}] {message} ({priority})\n"
    with _lock:
        with open(LOG_FILE, "a") as f:
