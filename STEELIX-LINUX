import socket, json, time, os, subprocess, signal, sys

REGION    = os.getenv("REGION_ID", "UNKNOWN")
BRAIN_IP  = "127.0.0.1"
BRAIN_PORT = 3004
READY_FILE = "/var/run/steelix/brain.ready"

def run(cmd):
    try: return subprocess.check_output(cmd, shell=True, timeout=3).decode().strip()
    except Exception: return "ERR"

def get_sig():
    if "BOULDER" in REGION:  return f"Iron Defense [{run('lsmod | wc -l')}]"
    if "CASCADE" in REGION:  return f"Bubble Beam [{run('ss -tunH | wc -l')}]"
    if "THUNDER" in REGION:
        raw = run("cat /sys/class/thermal/thermal_zone0/temp")
        temp = raw[:-3] if len(raw) > 3 else "0"
        return f"Thunderbolt [{temp}C]"
    if "RAINBOW" in REGION:  return f"Mega Drain [{run(\"df -h / | awk 'NR==2 {print $5}'\")  }]"
    if "SOUL"    in REGION:  return f"Toxic [{run('ps axo stat | grep -c Z || true')}]"
    if "MARSH"   in REGION:  return f"Future Sight [{run(\"free | grep Mem | awk '{print int($3/$2*100)}'\") }%]"
    if "VOLCANO" in REGION:  return f"Fire Blast [{os.getloadavg()[2]:.2f}]"
    if "EARTH"   in REGION:  return f"Earthquake [{run('who | wc -l')}]"
    return "-"

def wait_for_brain(timeout=60):
    deadline = time.time() + timeout
    while time.time() < deadline:
        if os.path.exists(READY_FILE): return True
        time.sleep(1)
    return False

def cleanup(signum, frame):
    sys.exit(0)

signal.signal(signal.SIGTERM, cleanup)
signal.signal(signal.SIGINT,  cleanup)

if not wait_for_brain(): sys.exit(1)

while True:
    try:
        tel = {"load": str(os.getloadavg()[0]), "signature": get_sig()}
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(5)
        s.connect((BRAIN_IP, BRAIN_PORT))
        s.sendall(json.dumps({"id": REGION, "data": tel}).encode())
        resp = s.recv(1024)
        if resp:
            order = json.loads(resp.decode()).get("order", "STANDBY")
            if order == "SILENCE": time.sleep(20)
        s.close()
    except ConnectionRefusedError:
        time.sleep(10)
        continue
    except Exception: pass
    time.sleep(5)
