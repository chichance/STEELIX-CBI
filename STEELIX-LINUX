wait_for_mysql || { echo "[!] MariaDB failed to start. Aborting."; exit 1; }

echo "[*] Provisioning database..."
DB_PASS="steelix_$(openssl rand -hex 8)"
cat > /etc/steelix.env << ENV
STEELIX_DB_HOST=localhost
STEELIX_DB_USER=steelix_user
STEELIX_DB_PASS=${DB_PASS}
STEELIX_DB_NAME=steelix_db
ENV
chmod 600 /etc/steelix.env

mysql -e "DROP USER IF EXISTS 'steelix_user'@'localhost';"
mysql -e "CREATE DATABASE IF NOT EXISTS steelix_db;"
mysql -e "CREATE USER 'steelix_user'@'localhost' IDENTIFIED BY '${DB_PASS}';"
mysql -e "GRANT ALL PRIVILEGES ON steelix_db.* TO 'steelix_user'@'localhost';"
mysql -e "FLUSH PRIVILEGES;"
mysql -e "
USE steelix_db;
CREATE TABLE IF NOT EXISTS system_logs (
    id          INT AUTO_INCREMENT PRIMARY KEY,
    timestamp   DATETIME DEFAULT CURRENT_TIMESTAMP,
    node_id     VARCHAR(50),
    event_type  VARCHAR(50),
    metric_signature TEXT,
    raw_payload TEXT,
    ai_score    FLOAT DEFAULT NULL,
    INDEX idx_node (node_id),
