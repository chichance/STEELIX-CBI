    if "BOULDER" in REGION:  return f"Iron Defense [{run('kextstat | tail -n +2 | wc -l').strip()}]"
    if "CASCADE" in REGION:  return f"Bubble Beam [{run('lsof -i -n -P | wc -l').strip()}]"
